{
  "name": "admin-panel-backend",
  "version": "1.0.0",
  "description": "Professional Admin Panel Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node scripts/seedUsers.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "prod": "NODE_ENV=production node server.js",
    "prod:win": "set NODE_ENV=production && node server.js",
    "prod:pm2": "pm2 start ecosystem.config.js --env production",
    "prod:docker": "docker-compose up -d",
    "logs": "tail -f logs/combined.log",
    "logs:error": "tail -f logs/error.log",
    "logs:pm2": "pm2 logs student-herald-api",
    "health": "curl http://localhost:3001/api/health",
    "prepare-deploy": "node prepare-deploy.js",
    "verify": "node verify-setup.js"
  },
  "dependencies": {
    "aws-sdk": "^2.1457.0",
    "axios": "^1.12.2",
    "bcryptjs": "^2.4.3",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.0.1",
    "form-data": "^4.0.5",
    "helmet": "^7.0.0",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.4",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.15.2",
    "nodemailer": "^6.9.5",
    "redis": "^4.6.8",
    "sequelize": "^6.32.1",
    "socket.io": "^4.7.2",
    "sqlite3": "^5.1.7",
    "uuid": "^9.0.0",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "jest": "^29.6.2",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  },
  "keywords": [
    "admin",
    "panel",
    "dashboard",
    "cms"
  ],
  "author": "Admin Panel Team",
  "license": "MIT"
}